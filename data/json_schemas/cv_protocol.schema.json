{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Batch",
    "type": "object",
    "required": ["metadata"],
    "properties": {
        "metadata": {
            "type": "object",
            "properties": {
                "batch_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "UUIDv4"
                },
                "camera": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": ["RGB", "IR"]
                        },
                        "height_position": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 6,
                            "description": "Camera vertical position index"
                        },
                        "direction": {
                            "type": "string",
                            "enum": ["left", "right"]
                        }
                    }
                },
                "captured_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 timestamp"
                },
                "zone": {
                    "type": "object",
                    "properties": {
                        "row_number": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "longitude": {
                            "type": "number"
                        }
                    }
                },
                "health_status": {
                    "type": "string",
                    "enum": ["healthy", "sick", "critical", "N/A"]
                },
                "processing_time": {
                    "type": "integer",
                    "description": "Image processing time in milliseconds"
                },
                "sensors": {
                    "type": "object",
                    "required": ["temperature", "humidity", "co2"],
                    "properties": {
                        "temperature": {
                            "type": "number",
                            "description": "Celsius"
                        },
                        "humidity": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "description": "Percent"
                        },
                        "co2": {
                            "type": "number",
                            "minimum": 0,
                            "description": "ppm"
                        }
                    }
                }
            }
        },
        "image": {
            "type": "string",
            "contentMediaType": "image/jpeg",
            "description": "Optional JPEG image (base64)"
        },
        "mask": {
            "type": "object",
            "properties": {
                "image": {
                    "type": "string",
                    "contentMediaType": "image/png",
                    "description": "Optional PNG mask (base64)"
                },
                "fruits": {
                    "type": "array",
                    "description": "Detected fruits bounding boxes",
                    "items": {
                        "type": "object",
                        "properties": {
                            "x": {
                                "type": "number",
                                "minimum": 0.0,
                                "maximum": 1.0,
                                "description": "Normalized bb center X"
                            },
                            "y": {
                                "type": "number",
                                "minimum": 0.0,
                                "maximum": 1.0,
                                "description": "Normalized bb center Y"
                            },
                            "w": {
                                "type": "number",
                                "minimum": 0.0,
                                "maximum": 1.0,
                                "description": "Normalized bb width"
                            },
                            "h": {
                                "type": "number",
                                "minimum": 0.0,
                                "maximum": 1.0,
                                "description": "Normalized bb height"
                            },
                            "bb_confidence": {
                                "type": "number",
                                "minimum": 0.0,
                                "maximum": 1.0
                            },
                            "ripeness": {
                                "type": "number",
                                "minimum": 0.0,
                                "maximum": 1.0
                            },
                            "ripeness_confidence": {
                                "type": "number",
                                "minimum": 0.0,
                                "maximum": 1.0
                            }
                        }
                    }
                }
            }
        },
        "raw": {
            "type": "string",
            "description": "Optional raw binary (requires image)"
        }
    }
}
